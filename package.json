{
  "name": "deepseek-desktop",
  "version": "0.1.0",
  "description": "Desktop workbench for the DeepSeek-TUI runtime (HTTP/SSE) — forked from DeepSeek GUI",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && npx --yes electron-builder@26.8.1 --config electron-builder.config.cjs --publish never",
    "dist:mac": "npm run dist -- --mac dmg zip --arm64 --x64",
    "dist:mac:signed": "MAC_SIGN=1 npm run dist -- --mac dmg zip --arm64 --x64",
    "dist:mac:arm64": "npm run dist -- --mac dmg zip --arm64",
    "dist:mac:x64": "npm run dist -- --mac dmg zip --x64",
    "dist:win": "npm run dist -- --win nsis --x64",
    "dist:linux": "npm run dist -- --linux AppImage --x64",
    "release:mac": "bash ./scripts/release-mac.sh",
    "release:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-win.ps1",
    "postinstall": "node ./scripts/postinstall.cjs",
    "verify:apple": "node ./scripts/verify-apple-signing.cjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "mac:unquarantine": "bash ./scripts/mac-unquarantine.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codewhale": "^0.8.47",
    "electron-store": "^11.0.2",
    "html-to-docx": "^1.8.0",
    "i18next": "^26.3.0",
    "lucide-react": "^1.17.0",
    "node-pty": "^1.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "rehype-harden": "^1.1.8",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/html-to-docx": "^1.8.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.3.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  },
  "author": "DeepSeek Desktop Contributors",
  "homepage": "https://github.com/coredds/DeepSeek-Desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/coredds/DeepSeek-Desktop.git"
  }
}
